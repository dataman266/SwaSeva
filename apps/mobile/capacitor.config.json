
{
  "appId": "in.swaseva.app",
  "appName": "Swaseva",
  "webDir": "dist",
  "bundledWebRuntime": false,
  "server": {
    "androidScheme": "https",
    "allowNavigation": ["*"]
  },
  "android": {
    "allowMixedContent": true,
    "captureInput": true,
    "backgroundColor": "#0E1A0E"
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 2000,
      "backgroundColor": "#0E1A0E",
      "showSpinner": true,
      "androidSpinnerStyle": "large"
    }
  }
}
