# Supabase — get from Supabase Dashboard → Settings → Database
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres"
DIRECT_URL="postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres"

# JWT — generate secure random strings, e.g.: openssl rand -hex 64
JWT_SECRET="change-this-to-a-secure-random-string"
JWT_ACCESS_SECRET="change-this-to-a-secure-random-string"
JWT_REFRESH_SECRET="change-this-to-a-different-secure-random-string"
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=30d

# OTP
OTP_EXPIRY_MINUTES=10
OTP_MAX_ATTEMPTS=5

# Rate limiting
THROTTLE_TTL=1000
THROTTLE_LIMIT=10

# Supabase API — get from Supabase Dashboard → Settings → API
SUPABASE_URL="https://[project-ref].supabase.co"
SUPABASE_ANON_KEY="your-anon-key-here"

PORT=3000
NODE_ENV=development
